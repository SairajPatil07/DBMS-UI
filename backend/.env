# Oracle DB Connection Config
# Fill in your Oracle credentials below

DB_USER=your_oracle_username
DB_PASSWORD=your_oracle_password
DB_CONNECTION_STRING=localhost/XEPDB1

# For Oracle XE: use  localhost/XEPDB1
# For Oracle 19c standard: use  localhost:1521/orcl
# For SQLPlus user (e.g. SYSTEM): use that username

PORT=5000
